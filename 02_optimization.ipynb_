{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyPqziDDgCJN+MeVV9w1Mx6u"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","source":["%%capture\n","!pip install catboost"],"metadata":{"id":"rwq3kqTFypQm","executionInfo":{"status":"ok","timestamp":1768063793614,"user_tz":-345,"elapsed":5058,"user":{"displayName":"Bishal Sharma","userId":"17711456069419286400"}}},"execution_count":8,"outputs":[]},{"cell_type":"code","execution_count":9,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"yFnKVmA0w9Nc","executionInfo":{"status":"ok","timestamp":1768063795899,"user_tz":-345,"elapsed":2283,"user":{"displayName":"Bishal Sharma","userId":"17711456069419286400"}},"outputId":"d81a7f0d-6f70-4875-c846-2e58d03c177a"},"outputs":[{"output_type":"stream","name":"stdout","text":["Drive already mounted at /content/gdrive; to attempt to forcibly remount, call drive.mount(\"/content/gdrive\", force_remount=True).\n","✓ Libraries imported!\n"]}],"source":["# ============================================================================\n","# FAST WORKING PIPELINE - OPTIMIZED FOR SPEED\n","# ============================================================================\n","\n","from google.colab import drive\n","drive.mount('/content/gdrive')\n","\n","import pandas as pd\n","import numpy as np\n","from sklearn.preprocessing import LabelEncoder\n","from sklearn.model_selection import KFold\n","from sklearn.metrics import mean_squared_error\n","from catboost import CatBoostRegressor\n","import warnings\n","warnings.filterwarnings('ignore')\n","\n","print(\"✓ Libraries imported!\")\n"]},{"cell_type":"code","source":["# ============================================================================\n","# Configuration\n","# ============================================================================\n","CONFIG = {\n","    'train_path': '/content/gdrive/MyDrive/Datathon/data/Train.csv',\n","    'test_path': '/content/gdrive/MyDrive/Datathon/data/Test.csv',\n","    'submission_path': '/content/gdrive/MyDrive/Datathon/final_submission.csv',\n","    'random_state': 42,\n","    'cv_folds': 5,\n","}\n"],"metadata":{"id":"BIH69QIOyfwu","executionInfo":{"status":"ok","timestamp":1768063795905,"user_tz":-345,"elapsed":5,"user":{"displayName":"Bishal Sharma","userId":"17711456069419286400"}}},"execution_count":10,"outputs":[]},{"cell_type":"code","source":["\n","# ============================================================================\n","# Data Processor\n","# ============================================================================\n","class FastDataProcessor:\n","    def __init__(self):\n","        self.age_order = [\n","            '< 1 year', '1-4 years', '5-14 years', '15-24 years',\n","            '25-34 years', '35-44 years', '45-54 years',\n","            '55-64 years', '65-74 years', '75-84 years', '85+ years'\n","        ]\n","        self.age_map = {age: i for i, age in enumerate(self.age_order)}\n","        self.state_stats = {}\n","        self.global_mean = 0\n","\n","    def clean_basic_columns(self, df):\n","        \"\"\"Basic cleaning\"\"\"\n","        # Sex\n","        df['Sex'] = df['Sex'].fillna(df.get('Sex Code', 'F'))\n","        df['Sex'] = df['Sex'].fillna('F')\n","        df['Sex'] = (df['Sex'] == 'M').astype(int)\n","\n","        # State and Age from combo\n","        if 'State_Age_Combo' in df.columns:\n","            split_data = df['State_Age_Combo'].str.split('_', n=1, expand=True)\n","            df['State'] = df['State'].fillna(split_data[0])\n","            age_from_combo = split_data[1].str.strip().str.replace(' years', '', regex=False)\n","            df['Ten-Year Age Groups'] = df['Ten-Year Age Groups'].fillna(age_from_combo)\n","\n","        # Year\n","        df['Year'] = df['Year'].fillna(df.get('Year Code'))\n","        df['Year'] = pd.to_numeric(df['Year'], errors='coerce')\n","        df['Year'] = np.floor(df['Year']).astype('Int64')\n","        df['Year'] = df['Year'].fillna(df['Year'].median())\n","\n","        # Death percentage\n","        if '% of Total Deaths' in df.columns:\n","            df['% of Total Deaths'] = pd.to_numeric(df['% of Total Deaths'], errors='coerce')\n","            df['% of Total Deaths'] = df['% of Total Deaths'].clip(0, 1)\n","\n","        # Population\n","        df['Population'] = pd.to_numeric(df['Population'], errors='coerce')\n","        if 'adjusted_pop_trend' in df.columns:\n","            df['Population'] = df['Population'].fillna(df['adjusted_pop_trend'])\n","        df['Population'] = df['Population'].fillna(df['Population'].median())\n","\n","        # Rates\n","        for col in ['Crude Rate', 'Crude Rate Standard Error']:\n","            if col in df.columns:\n","                df[col] = pd.to_numeric(df[col], errors='coerce')\n","                df[col] = df[col].fillna(df[col].median())\n","\n","        # Sensor data\n","        for col in ['temp_sensor_readout', 'qc_flag_batch_3', 'legacy_index_offset']:\n","            if col in df.columns:\n","                df[col] = pd.to_numeric(df[col], errors='coerce')\n","                df[col] = df[col].fillna(0)\n","\n","        # Contributing Cause\n","        if 'Contributing_Cause' in df.columns:\n","            df['Contributing_Cause'] = pd.to_numeric(df['Contributing_Cause'], errors='coerce')\n","            df['Contributing_Cause'] = df['Contributing_Cause'].fillna(0)\n","\n","        # Categorical\n","        for col in ['State', 'Underlying_Cause', 'Manner_of_Death']:\n","            if col in df.columns:\n","                df[col] = df[col].astype(str).fillna('Unknown')\n","\n","        # Drop unnecessary\n","        drop_cols = [\n","            'Id', 'Sex Code', 'State Code', 'Year Code', 'Ten-Year Age Groups Code',\n","            'State_Age_Combo', 'Year_dt', 'adjusted_pop_trend',\n","            'confidence_spread_metric', 'temporal_alignment_proxy',\n","            'Crude Rate Lower 95% Confidence Interval',\n","            'Crude Rate Upper 95% Confidence Interval'\n","        ]\n","        df = df.drop(columns=[c for c in drop_cols if c in df.columns])\n","\n","        return df\n","\n","    def create_features(self, df, is_train=True):\n","        \"\"\"Create features\"\"\"\n","        # Age encoding\n","        df['Age_Ordinal'] = df['Ten-Year Age Groups'].map(self.age_map)\n","        df['Age_Ordinal'] = df['Age_Ordinal'].fillna(5)  # Middle age as default\n","\n","        # Interaction features\n","        df['State_Year'] = df['State'].astype(str) + '_' + df['Year'].astype(str)\n","        df['State_Age'] = df['State'].astype(str) + '_' + df['Age_Ordinal'].astype(str)\n","\n","        # Statistical features\n","        if 'Crude Rate' in df.columns and 'Population' in df.columns:\n","            df['Death_Est'] = (df['Crude Rate'] * df['Population'] / 100000).fillna(0)\n","\n","        if 'Crude Rate' in df.columns and 'Crude Rate Standard Error' in df.columns:\n","            df['Rate_Confidence'] = 1 / (df['Crude Rate Standard Error'] + 0.01)\n","\n","        # Age features\n","        df['Is_Elderly'] = (df['Age_Ordinal'] >= 8).astype(int)\n","        df['Is_Young'] = (df['Age_Ordinal'] <= 2).astype(int)\n","        df['Age_Squared'] = df['Age_Ordinal'] ** 2\n","\n","        # Population features\n","        if 'Population' in df.columns:\n","            df['Log_Pop'] = np.log1p(df['Population'])\n","\n","        # Time features\n","        if 'Year' in df.columns:\n","            df['Year_Since_2000'] = df['Year'] - 2000\n","\n","        # Target encoding (train only)\n","        if is_train and 'Target' in df.columns:\n","            self.global_mean = df['Target'].mean()\n","\n","            # State encoding with smoothing\n","            state_agg = df.groupby('State')['Target'].agg(['mean', 'count'])\n","            smoothing = 10\n","            state_agg['smooth_mean'] = (\n","                (state_agg['mean'] * state_agg['count'] + self.global_mean * smoothing) /\n","                (state_agg['count'] + smoothing)\n","            )\n","            self.state_stats = state_agg['smooth_mean'].to_dict()\n","\n","        # Apply state encoding\n","        if self.state_stats:\n","            df['State_Target'] = df['State'].map(self.state_stats).fillna(self.global_mean)\n","\n","        # Frequency encoding\n","        for col in ['State', 'Underlying_Cause', 'Manner_of_Death']:\n","            if col in df.columns:\n","                freq = df[col].value_counts(normalize=True).to_dict()\n","                df[f'{col}_Freq'] = df[col].map(freq).fillna(0)\n","\n","        return df\n","\n","    def fit_transform(self, df):\n","        \"\"\"Process training data\"\"\"\n","        print(\"  → Cleaning...\")\n","        df = self.clean_basic_columns(df)\n","        print(\"  → Creating features...\")\n","        df = self.create_features(df, is_train=True)\n","        print(f\"✓ Done! Shape: {df.shape}\")\n","        return df\n","\n","    def transform(self, df):\n","        \"\"\"Process test data\"\"\"\n","        print(\"  → Cleaning...\")\n","        df = self.clean_basic_columns(df)\n","        print(\"  → Creating features...\")\n","        df = self.create_features(df, is_train=False)\n","        print(f\"✓ Done! Shape: {df.shape}\")\n","        return df"],"metadata":{"id":"6VXBobfiy2LR","executionInfo":{"status":"ok","timestamp":1768063795935,"user_tz":-345,"elapsed":27,"user":{"displayName":"Bishal Sharma","userId":"17711456069419286400"}}},"execution_count":11,"outputs":[]},{"cell_type":"code","source":["\n","# ============================================================================\n","# Model Trainer\n","# ============================================================================\n","class FastTrainer:\n","    def __init__(self, random_state=42):\n","        self.random_state = random_state\n","        self.model = None\n","        self.cat_features = []\n","\n","    def get_cat_features(self, X):\n","        \"\"\"Identify categorical features\"\"\"\n","        cat_features = []\n","        for col in X.columns:\n","            if X[col].dtype == 'object' or pd.api.types.is_categorical_dtype(X[col]):\n","                cat_features.append(col)\n","        return cat_features\n","\n","    def get_best_params(self):\n","        \"\"\"Return optimized parameters (pre-tuned)\"\"\"\n","        return {\n","            'iterations': 1200,\n","            'depth': 8,\n","            'learning_rate': 0.03,\n","            'l2_leaf_reg': 5,\n","            'min_data_in_leaf': 20,\n","            'random_strength': 0.5,\n","            'bagging_temperature': 0.2,\n","            'border_count': 254,\n","            'loss_function': 'RMSE',\n","            'random_seed': self.random_state,\n","            'verbose': False,\n","            'early_stopping_rounds': 50,\n","            'task_type': 'CPU'  # Using CPU for compatibility\n","        }\n","\n","    def train(self, X, y):\n","        \"\"\"Train model\"\"\"\n","        self.cat_features = self.get_cat_features(X)\n","        params = self.get_best_params()\n","        params['cat_features'] = self.cat_features\n","\n","        print(f\"  Training with {len(self.cat_features)} categorical features...\")\n","        self.model = CatBoostRegressor(**params)\n","        self.model.fit(X, y)\n","        return self.model\n","\n","    def predict(self, X):\n","        \"\"\"Make predictions\"\"\"\n","        return self.model.predict(X)\n","\n","    def evaluate_oof(self, X, y, n_splits=5):\n","        \"\"\"Out-of-fold evaluation\"\"\"\n","        kf = KFold(n_splits=n_splits, shuffle=True, random_state=self.random_state)\n","        oof_preds = np.zeros(len(X))\n","\n","        cat_features = self.get_cat_features(X)\n","        params = self.get_best_params()\n","        params['cat_features'] = cat_features\n","\n","        for fold, (train_idx, val_idx) in enumerate(kf.split(X), 1):\n","            print(f\"    Fold {fold}/{n_splits}...\", end=\" \")\n","            X_tr, X_val = X.iloc[train_idx], X.iloc[val_idx]\n","            y_tr, y_val = y.iloc[train_idx], y.iloc[val_idx]\n","\n","            model = CatBoostRegressor(**params)\n","            model.fit(X_tr, y_tr, eval_set=(X_val, y_val), verbose=False)\n","            oof_preds[val_idx] = model.predict(X_val)\n","            print(\"✓\")\n","\n","        rmse = np.sqrt(mean_squared_error(y, oof_preds))\n","        return rmse, oof_preds\n","\n","    def get_feature_importance(self, top_n=20):\n","        \"\"\"Get feature importance\"\"\"\n","        if self.model is None:\n","            return None\n","\n","        importance = pd.DataFrame({\n","            'feature': self.model.feature_names_,\n","            'importance': self.model.feature_importances_\n","        }).sort_values('importance', ascending=False).head(top_n)\n","\n","        return importance"],"metadata":{"id":"au_hdK0ey9CE","executionInfo":{"status":"ok","timestamp":1768063795952,"user_tz":-345,"elapsed":14,"user":{"displayName":"Bishal Sharma","userId":"17711456069419286400"}}},"execution_count":12,"outputs":[]},{"cell_type":"code","source":["\n","# ============================================================================\n","# Main Pipeline\n","# ============================================================================\n","print(\"\\n\" + \"=\"*70)\n","print(\"STEP 1: LOADING DATA\")\n","print(\"=\"*70)\n","\n","train_df = pd.read_csv(CONFIG['train_path'])\n","print(f\"✓ Train: {train_df.shape}\")\n","\n","try:\n","    test_df = pd.read_csv(CONFIG['test_path'])\n","    print(f\"✓ Test: {test_df.shape}\")\n","    has_test = True\n","except:\n","    print(\"⚠ No test data\")\n","    test_df = None\n","    has_test = False\n","\n","# ============================================================================\n","print(\"\\n\" + \"=\"*70)\n","print(\"STEP 2: PROCESSING DATA\")\n","print(\"=\"*70)\n","\n","processor = FastDataProcessor()\n","\n","print(\"\\nTrain:\")\n","train_processed = processor.fit_transform(train_df)\n","\n","if has_test:\n","    print(\"\\nTest:\")\n","    test_processed = processor.transform(test_df)\n","\n","# ============================================================================\n","print(\"\\n\" + \"=\"*70)\n","print(\"STEP 3: PREPARING FEATURES\")\n","print(\"=\"*70)\n","\n","# Prepare training data\n","train_data = train_processed[train_processed['Target'].notna()].copy()\n","X_train = train_data.drop(columns=['Target', 'Ten-Year Age Groups'], errors='ignore')\n","y_train = train_data['Target']\n","\n","print(f\"✓ Samples: {len(X_train)}\")\n","print(f\"✓ Features: {X_train.shape[1]}\")\n","print(f\"✓ Target mean: {y_train.mean():.2f}\")\n","\n","# Prepare test data\n","if has_test:\n","    X_test = test_processed.drop(columns=['Target', 'Ten-Year Age Groups'], errors='ignore')\n","\n","    # Align columns\n","    common_cols = list(set(X_train.columns) & set(X_test.columns))\n","    X_train = X_train[common_cols]\n","    X_test = X_test[common_cols]\n","    print(f\"✓ Using {len(common_cols)} common features\")\n","\n","# ============================================================================\n","print(\"\\n\" + \"=\"*70)\n","print(\"STEP 4: EVALUATING MODEL\")\n","print(\"=\"*70)\n","\n","trainer = FastTrainer(random_state=CONFIG['random_state'])\n","\n","print(\"\\nOut-of-Fold Evaluation:\")\n","oof_rmse, oof_preds = trainer.evaluate_oof(X_train, y_train, n_splits=CONFIG['cv_folds'])\n","print(f\"\\nOOF RMSE: {oof_rmse:.2f}\")\n","\n","# Baseline comparison\n","baseline_rmse = np.sqrt(np.mean((y_train - y_train.mean()) ** 2))\n","improvement = (1 - oof_rmse/baseline_rmse) * 100\n","\n","print(\"\\n\" + \"=\"*70)\n","print(\"PERFORMANCE SUMMARY\")\n","print(\"=\"*70)\n","print(f\"Baseline RMSE: {baseline_rmse:.2f}\")\n","print(f\"Model RMSE: {oof_rmse:.2f}\")\n","print(f\"Improvement: {improvement:.2f}%\")\n","print(\"=\"*70)\n","\n","# ============================================================================\n","print(\"\\n\" + \"=\"*70)\n","print(\"STEP 5: TRAINING FINAL MODEL\")\n","print(\"=\"*70)\n","\n","print(\"Training on full data...\")\n","trainer.train(X_train, y_train)\n","print(\"✓ Model trained!\")\n","\n","# Feature importance\n","print(\"\\nTop 20 Features:\")\n","importance = trainer.get_feature_importance(20)\n","if importance is not None:\n","    for idx, row in importance.iterrows():\n","        print(f\"  {row['feature']:30s}: {row['importance']:.4f}\")\n","\n","# ============================================================================\n","if has_test:\n","    print(\"\\n\" + \"=\"*70)\n","    print(\"STEP 6: GENERATING PREDICTIONS\")\n","    print(\"=\"*70)\n","\n","    print(\"Predicting...\")\n","    predictions = trainer.predict(X_test)\n","\n","    # Ensure non-negative\n","    predictions = np.maximum(predictions, 0)\n","\n","    # Create submission\n","    submission = pd.DataFrame({\n","        'Id': test_df['Id'],\n","        'Target': predictions\n","    })\n","\n","    # Handle duplicates\n","    submission = submission.groupby('Id', as_index=False).agg({'Target': 'mean'})\n","\n","    print(f\"\\n✓ Submission: {len(submission)} rows\")\n","    print(f\"  Mean: {predictions.mean():.2f}\")\n","    print(f\"  Std: {predictions.std():.2f}\")\n","    print(f\"  Min: {predictions.min():.2f}\")\n","    print(f\"  Max: {predictions.max():.2f}\")\n","\n","    # Save\n","    submission.to_csv(CONFIG['submission_path'], index=False)\n","    print(f\"\\n✓ Saved to: {CONFIG['submission_path']}\")\n","\n","print(\"\\n\" + \"=\"*70)\n","print(\"PIPELINE COMPLETED! 🎉\")\n","print(\"=\"*70)\n","if has_test:\n","    print(f\"\\nSubmission ready: {CONFIG['submission_path']}\")\n","    print(f\"Expected RMSE: ~{oof_rmse:.0f}\")\n","print(\"=\"*70)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"y4M39Xc4zAWJ","executionInfo":{"status":"ok","timestamp":1768063940578,"user_tz":-345,"elapsed":144615,"user":{"displayName":"Bishal Sharma","userId":"17711456069419286400"}},"outputId":"1536abba-56ae-48f6-a307-a9677174748c"},"execution_count":13,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","======================================================================\n","STEP 1: LOADING DATA\n","======================================================================\n","✓ Train: (11879, 27)\n","✓ Test: (5092, 25)\n","\n","======================================================================\n","STEP 2: PROCESSING DATA\n","======================================================================\n","\n","Train:\n","  → Cleaning...\n","  → Creating features...\n","✓ Done! Shape: (11879, 29)\n","\n","Test:\n","  → Cleaning...\n","  → Creating features...\n","✓ Done! Shape: (5092, 28)\n","\n","======================================================================\n","STEP 3: PREPARING FEATURES\n","======================================================================\n","✓ Samples: 7459\n","✓ Features: 27\n","✓ Target mean: 2345.64\n","✓ Using 27 common features\n","\n","======================================================================\n","STEP 4: EVALUATING MODEL\n","======================================================================\n","\n","Out-of-Fold Evaluation:\n","    Fold 1/5... ✓\n","    Fold 2/5... ✓\n","    Fold 3/5... ✓\n","    Fold 4/5... ✓\n","    Fold 5/5... ✓\n","\n","OOF RMSE: 9401.37\n","\n","======================================================================\n","PERFORMANCE SUMMARY\n","======================================================================\n","Baseline RMSE: 14233.08\n","Model RMSE: 9401.37\n","Improvement: 33.95%\n","======================================================================\n","\n","======================================================================\n","STEP 5: TRAINING FINAL MODEL\n","======================================================================\n","Training on full data...\n","  Training with 5 categorical features...\n","✓ Model trained!\n","\n","Top 20 Features:\n","  Rate_Confidence               : 15.0477\n","  % of Total Deaths             : 11.4783\n","  State_Year                    : 9.3146\n","  Crude Rate Standard Error     : 6.9386\n","  State_Age                     : 6.9143\n","  Death_Est                     : 5.1030\n","  State_Target                  : 5.0325\n","  Population                    : 4.5332\n","  Crude Rate                    : 4.5280\n","  Year_Since_2000               : 4.2574\n","  Year                          : 4.1149\n","  State                         : 3.6009\n","  qc_flag_batch_3               : 2.3519\n","  legacy_index_offset           : 2.1856\n","  Contributing_Cause            : 2.1026\n","  Log_Pop                       : 2.0521\n","  temp_sensor_readout           : 1.9933\n","  State_Freq                    : 1.5787\n","  Age_Ordinal                   : 1.4433\n","  Age_Squared                   : 1.4021\n","\n","======================================================================\n","STEP 6: GENERATING PREDICTIONS\n","======================================================================\n","Predicting...\n","\n","✓ Submission: 4715 rows\n","  Mean: 2574.88\n","  Std: 4345.71\n","  Min: 0.00\n","  Max: 42255.22\n","\n","✓ Saved to: /content/gdrive/MyDrive/Datathon/final_submission.csv\n","\n","======================================================================\n","PIPELINE COMPLETED! 🎉\n","======================================================================\n","\n","Submission ready: /content/gdrive/MyDrive/Datathon/final_submission.csv\n","Expected RMSE: ~9401\n","======================================================================\n"]}]},{"cell_type":"code","source":[],"metadata":{"id":"6VXmL0f4zSyc","executionInfo":{"status":"ok","timestamp":1768063940579,"user_tz":-345,"elapsed":3,"user":{"displayName":"Bishal Sharma","userId":"17711456069419286400"}}},"execution_count":13,"outputs":[]}]}